# Required: Your Anthropic API key
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional: Maximum pages to crawl (default: 50)
MAX_PAGES=50

# Optional: Screenshot JPEG quality (default: 80)
SCREENSHOT_QUALITY=80

# Optional: Crawl timeout in milliseconds (default: 120000)
CRAWL_TIMEOUT=120000
